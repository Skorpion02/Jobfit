# ===================================================
# JOBFIT AGENT - CONFIGURACIÓN DE ENTORNO
# ===================================================
# Copia este archivo como .env para personalizar la configuración

# === LM STUDIO CONFIGURATION ===
# URL base del servidor LM Studio local
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Modelo principal a utilizar (se detectará automáticamente)
LMSTUDIO_MODEL=local-model

# Usar LM Studio para procesamiento (true/false)
USE_LMSTUDIO=true

# === MODEL CONFIGURATION ===
# Modelo de embeddings para análisis semántico
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Modelo LLM alternativo (si no usas LM Studio)
LLM_MODEL=gpt-4o-mini

# === SCRAPING SETTINGS ===
SCRAPING_TIMEOUT=30
MAX_RETRIES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# === PROCESSING LIMITS ===
MAX_CV_SIZE_MB=10
MAX_JOB_DESCRIPTION_LENGTH=10000

# === MATCHING THRESHOLDS ===
SEMANTIC_SIMILARITY_THRESHOLD=0.7
EXACT_MATCH_THRESHOLD=0.9

# === EXPORT SETTINGS ===
EXPORT_FORMAT=docx
TEMPLATE_PATH=data/templates/
TEMP_PATH=data/temp/

# ===================================================
# NOTAS:
# - LM Studio debe estar corriendo en http://localhost:1234
# - Si cambias el puerto en LM Studio, actualiza LMSTUDIO_BASE_URL
# - El modelo se seleccionará automáticamente del primer disponible
# ===================================================
